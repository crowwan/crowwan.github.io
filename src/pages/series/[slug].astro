---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SERIES, SITE_TITLE } from '../../consts';
import { getExcerpt } from '../../utils/excerpt';
import { getSeriesPosts } from '../../utils/series';

// SERIES 에 등록된 시리즈마다 페이지를 하나씩 만든다.
export function getStaticPaths() {
	return Object.entries(SERIES).map(([seriesName, meta]) => ({
		params: { slug: meta.slug },
		props: { seriesName, description: meta.description },
	}));
}

interface Props {
	seriesName: string;
	description: string;
}

const { seriesName, description } = Astro.props;
const posts = getSeriesPosts(await getCollection('blog'), seriesName);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`${seriesName} · ${SITE_TITLE}`} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-head reveal">
				<p class="eyebrow">연재</p>
				<h1 class="page-title">{seriesName}</h1>
				<p class="page-sub">{description}</p>
				<p class="page-count">{posts.length}편</p>
			</header>

			<ol class="article-list series-list">
				{
					posts.map((post, i) => {
						const excerpt = getExcerpt(post.data.description, post.body);
						return (
							<li class="reveal" style={`animation-delay: ${i * 70}ms`}>
								<a class="article no-thumb" href={`/blog/${post.id}/`}>
									<div class="article-meta">
										<span class="seq">#{post.data.seriesOrder ?? i + 1}</span>
										<span class="dot" aria-hidden="true">
											·
										</span>
										<FormattedDate date={post.data.pubDate} />
									</div>
									<h2 class="article-title">{post.data.title}</h2>
									{excerpt && <p class="article-excerpt">{excerpt}</p>}
								</a>
							</li>
						);
					})
				}
			</ol>

			<nav class="post-nav">
				<a class="back" href="/series"><span aria-hidden="true">←</span> 시리즈 목록</a>
			</nav>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-head {
		margin-bottom: 2.6em;
	}
	.page-head .eyebrow {
		margin: 0 0 0.7em;
	}
	.page-title {
		font-family: var(--font-sans);
		font-weight: 800;
		font-size: clamp(2.2rem, 6.5vw, 3.2rem);
		line-height: 1.2;
		letter-spacing: -0.03em;
		color: var(--text-strong);
		margin: 0;
	}
	.page-sub {
		font-family: var(--font-sans);
		font-size: 1.05rem;
		line-height: 1.6;
		color: var(--text-2);
		margin: 0.7em 0 0;
		max-width: 52ch;
	}
	.page-count {
		font-family: var(--font-sans);
		font-size: 0.92rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: var(--text-meta);
		margin: 0.6em 0 0;
	}
	/* ol 기본 마커 제거 — 순번은 카드 안 .seq 로 표시한다. */
	.series-list {
		counter-reset: none;
	}
	.article-meta .seq {
		color: var(--accent);
		font-weight: 700;
	}
	.post-nav {
		max-width: var(--content-width);
		margin: 3em auto 0;
		padding-top: 1.8em;
		border-top: 1px solid var(--border);
	}
	.back {
		font-family: var(--font-sans);
		font-size: 0.92rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: var(--text-meta);
		text-decoration: none;
		transition: color 0.18s ease;
	}
	.back:hover {
		color: var(--accent);
	}
</style>
