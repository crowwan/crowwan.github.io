---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getAllSeries } from '../../utils/series';

const seriesList = getAllSeries(await getCollection('blog'));
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead
			title={`시리즈 · ${SITE_TITLE}`}
			description="주제별로 이어 쓴 연재 모아보기."
		/>
	</head>
	<body>
		<Header />
		<main>
			<header class="page-head reveal">
				<p class="eyebrow">연재</p>
				<h1 class="page-title">시리즈</h1>
				<p class="page-count">{seriesList.length}개의 연재</p>
			</header>

			<ul class="article-list">
				{
					seriesList.map((series, i) => {
						const single = series.earliest.valueOf() === series.latest.valueOf();
						return (
							<li class="reveal" style={`animation-delay: ${i * 70}ms`}>
								<a class="article no-thumb" href={`/series/${series.slug}/`}>
									<div class="article-meta">
										<span class="cat">{series.posts.length}편</span>
										<span class="dot" aria-hidden="true">
											·
										</span>
										{single ? (
											<FormattedDate date={series.latest} />
										) : (
											<span class="range">
												<FormattedDate date={series.earliest} />
												<span aria-hidden="true"> – </span>
												<FormattedDate date={series.latest} />
											</span>
										)}
									</div>
									<h2 class="article-title">{series.name}</h2>
									<p class="article-excerpt">{series.description}</p>
								</a>
							</li>
						);
					})
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-head {
		margin-bottom: 2.6em;
	}
	.page-head .eyebrow {
		margin: 0 0 0.7em;
	}
	.page-title {
		font-family: var(--font-sans);
		font-weight: 800;
		font-size: clamp(2.2rem, 6.5vw, 3.2rem);
		line-height: 1.2;
		letter-spacing: -0.03em;
		color: var(--text-strong);
		margin: 0;
	}
	.page-count {
		font-family: var(--font-sans);
		font-size: 0.92rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: var(--text-meta);
		margin: 0.7em 0 0;
	}
	/* 발행일 범위는 한 줄로 이어 보여준다. */
	.range {
		display: inline-flex;
		align-items: center;
		gap: 0.15rem;
	}
</style>
