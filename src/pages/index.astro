---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getExcerpt } from '../utils/excerpt';

// 최근 글 5개 (발행일 역순).
const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="masthead">
				<p class="eyebrow reveal" style="animation-delay: 0ms">DEV JOURNAL · SINCE 2022</p>
				<h1 class="masthead-title reveal" style="animation-delay: 90ms">
					오늘의 생각을<br /><em>기록</em>합니다
				</h1>
				<p class="masthead-sub reveal" style="animation-delay: 180ms">
					매일의 개발 기록을 마크다운으로 쌓아 갑니다 — 클로드, 자동화, 그리고 읽는 맛.
				</p>
			</section>

			<hr class="masthead-rule reveal" style="animation-delay: 260ms" />

			<section class="recent">
				<p class="section-label eyebrow reveal" style="animation-delay: 300ms">최근 글</p>
				<ul class="article-list">
					{
						recentPosts.map((post, i) => {
							const excerpt = getExcerpt(post.data.description, post.body);
							const cat = post.data.tags?.[0];
							const isFeature = i === 0;
							return (
								<li>
									<a
										class:list={['article', 'reveal', { feature: isFeature, 'no-thumb': true }]}
										href={`/blog/${post.id}/`}
										style={`animation-delay: ${360 + i * 70}ms`}
									>
										<div class="article-meta">
											{cat && <span class="cat">{cat}</span>}
											{cat && <span class="dot" aria-hidden="true">·</span>}
											<FormattedDate date={post.data.pubDate} />
										</div>
										<h2 class="article-title">{post.data.title}</h2>
										{excerpt && <p class="article-excerpt">{excerpt}</p>}
									</a>
								</li>
							);
						})
					}
				</ul>

				<a class="all-link reveal" href="/blog" style="animation-delay: 760ms">
					전체 글 보기 <span aria-hidden="true">→</span>
				</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.masthead {
		padding: 1.5em 0 1.8em;
	}
	.masthead .eyebrow {
		margin: 0 0 1.2em;
	}
	.masthead-title {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: clamp(3.5rem, 12vw, 6rem);
		line-height: 1.02;
		letter-spacing: -0.025em;
		margin: 0;
		color: var(--ink);
	}
	.masthead-title em {
		font-style: italic;
		color: var(--accent);
	}
	.masthead-sub {
		font-family: var(--font-serif);
		font-size: 1.18rem;
		line-height: 1.65;
		color: var(--ink-soft);
		margin: 1.2em 0 0;
		max-width: 36ch;
	}
	.masthead-rule {
		margin: 1.8em 0 0;
	}

	.section-label {
		margin: 2.4em 0 0.2em;
	}

	.all-link {
		display: inline-block;
		margin-top: 2.4em;
		font-family: var(--font-ui);
		font-size: 0.78rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--accent);
		text-decoration: none;
		transition: color 0.18s ease;
	}
	.all-link:hover {
		color: var(--accent-deep);
	}
</style>
