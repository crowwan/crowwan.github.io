---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getExcerpt } from '../../utils/excerpt';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// 발행 연도별 그룹핑 (내림차순).
type Post = (typeof posts)[number];
const groups = new Map<number, Post[]>();
for (const post of posts) {
	const year = post.data.pubDate.getFullYear();
	if (!groups.has(year)) groups.set(year, []);
	groups.get(year)!.push(post);
}
const years = [...groups.keys()].sort((a, b) => b - a);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`글 · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-head reveal">
				<p class="eyebrow">아카이브</p>
				<h1 class="page-title">전체 글</h1>
				<p class="page-count">{posts.length}편의 기록</p>
			</header>

			{
				years.map((year, gi) => (
					<section class="year-group">
						<div class="year-head reveal" style={`animation-delay: ${gi * 70}ms`}>
							<span class="year">{year}</span>
							<span class="year-count">{groups.get(year)!.length}편</span>
						</div>
						<ul class="article-list">
							{groups.get(year)!.map((post) => {
								const excerpt = getExcerpt(post.data.description, post.body);
								const cat = post.data.tags?.[0];
								const hasThumb = Boolean(post.data.heroImage);
								return (
									<li>
										<a
											class:list={['article', { 'no-thumb': !hasThumb }]}
											href={`/blog/${post.id}/`}
										>
											<div class="article-meta">
												{cat && <span class="cat">{cat}</span>}
												{cat && (
													<span class="dot" aria-hidden="true">
														·
													</span>
												)}
												<FormattedDate date={post.data.pubDate} />
											</div>
											<h2 class="article-title">{post.data.title}</h2>
											{excerpt && <p class="article-excerpt">{excerpt}</p>}
											{hasThumb && (
												<img
													class="article-thumb"
													src={post.data.heroImage}
													alt=""
													loading="lazy"
												/>
											)}
										</a>
									</li>
								);
							})}
						</ul>
					</section>
				))
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-head {
		margin-bottom: 2.6em;
	}
	.page-head .eyebrow {
		margin: 0 0 0.7em;
	}
	.page-title {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: clamp(2.6rem, 8vw, 4rem);
		line-height: 1.05;
		letter-spacing: -0.02em;
		margin: 0;
	}
	.page-count {
		font-family: var(--font-ui);
		font-size: 0.78rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--ink-faint);
		margin: 0.7em 0 0;
	}

	.year-group {
		margin-bottom: 3em;
	}
	.year-head {
		display: flex;
		align-items: baseline;
		gap: 0.9rem;
		padding-bottom: 0.4em;
		margin-bottom: 0.2em;
	}
	.year {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: clamp(2.4rem, 7vw, 3.4rem);
		line-height: 1;
		letter-spacing: -0.02em;
		color: var(--ink);
	}
	.year-count {
		font-family: var(--font-ui);
		font-size: 0.72rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--ink-faint);
	}
</style>
