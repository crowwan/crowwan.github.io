---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	// 읽기 시간 추정을 위한 본문 글자수(선택).
	charCount?: number;
};

const { title, description, pubDate, updatedDate, heroImage, tags, charCount } = Astro.props;

// 한글 글자수 기반 읽기 시간 추정 (분당 약 500자).
const readingMinutes = charCount ? Math.max(1, Math.round(charCount / 500)) : null;
const category = tags?.[0];
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description ?? ''} image={heroImage} />
	</head>

	<body>
		<div class="progress-bar" id="reading-progress"></div>
		<Header />
		<main>
			<article>
				<header class="post-head reveal">
					<div class="kicker-row">
						{category && <span class="cat">{category}</span>}
						{category && <span class="dot" aria-hidden="true">·</span>}
						<FormattedDate date={pubDate} />
						{readingMinutes && <span class="dot" aria-hidden="true">·</span>}
						{readingMinutes && <span>{readingMinutes}분 읽기</span>}
						{
							updatedDate && (
								<span class="updated">
									<span class="dot" aria-hidden="true">
										·
									</span>
									업데이트 <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</div>

					<h1 class="post-title">{title}</h1>
					{description && <p class="post-sub">{description}</p>}

					{
						tags && tags.length > 0 && (
							<div class="post-tags">
								{tags.map((tag) => (
									<span class="tag">{tag}</span>
								))}
							</div>
						)
					}
				</header>

				{
					heroImage && (
						<figure class="hero-image reveal">
							<img src={heroImage} alt="" loading="lazy" />
						</figure>
					)
				}

				<div class="prose reveal">
					<slot />
				</div>

				<nav class="post-nav">
					<a class="back" href="/blog"><span aria-hidden="true">←</span> 목록으로</a>
				</nav>
			</article>
		</main>
		<Footer />

		<script is:inline>
			// 스크롤 기반 읽기 진행도 표시.
			(function () {
				const bar = document.getElementById('reading-progress');
				if (!bar) return;
				const onScroll = () => {
					const doc = document.documentElement;
					const scrollTop = doc.scrollTop || document.body.scrollTop;
					const height = doc.scrollHeight - doc.clientHeight;
					const ratio = height > 0 ? scrollTop / height : 0;
					bar.style.transform = 'scaleX(' + Math.min(1, Math.max(0, ratio)) + ')';
				};
				document.addEventListener('scroll', onScroll, { passive: true });
				onScroll();
			})();
		</script>

		<style>
			.progress-bar {
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				height: 2px;
				background: var(--accent);
				transform-origin: 0 0;
				transform: scaleX(0);
				z-index: 100;
			}
			.post-head {
				max-width: var(--prose-width);
				margin: 0 auto 2.2em;
			}
			.kicker-row {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.55rem;
				font-family: var(--font-sans);
				font-size: 0.85rem;
				font-weight: 600;
				letter-spacing: -0.01em;
				color: var(--text-meta);
				margin-bottom: 1.2em;
			}
			.kicker-row .cat {
				color: var(--accent);
				font-weight: 700;
			}
			.kicker-row .dot {
				color: var(--text-faint);
			}
			.post-title {
				font-family: var(--font-sans);
				font-weight: 800;
				font-size: clamp(2rem, 5.5vw, 3rem);
				letter-spacing: -0.03em;
				line-height: 1.25;
				margin: 0 0 0.5em;
				color: var(--text-strong);
			}
			.post-sub {
				font-family: var(--font-sans);
				font-size: 1.15rem;
				line-height: 1.6;
				color: var(--text-2);
				margin: 0 0 1.2em;
				max-width: 52ch;
			}
			.post-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				padding-top: 1.2em;
				border-top: 1px solid var(--border);
			}
			.hero-image {
				margin: 0 auto 2.6em;
				max-width: var(--content-width);
			}
			.hero-image img {
				display: block;
				width: 100%;
				border-radius: var(--radius-lg);
				border: 1px solid var(--border);
			}
			.post-nav {
				max-width: var(--prose-width);
				margin: 4em auto 0;
				padding-top: 1.8em;
				border-top: 1px solid var(--border);
			}
			.back {
				font-family: var(--font-sans);
				font-size: 0.92rem;
				font-weight: 600;
				letter-spacing: -0.01em;
				color: var(--text-meta);
				text-decoration: none;
				transition: color 0.18s ease;
			}
			.back:hover {
				color: var(--accent);
			}
		</style>
	</body>
</html>
