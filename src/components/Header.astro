---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<div class="bar">
		<a class="logo" href="/">{SITE_TITLE}</a>
		<nav class="internal-links" aria-label="주 메뉴">
			<HeaderLink href="/blog">글</HeaderLink>
			<HeaderLink href="/about">소개</HeaderLink>
		</nav>
		<div class="social-links">
			<a href="https://velog.io/@crowwan" target="_blank" rel="noopener">velog</a>
			<a href="https://github.com/crowwan" target="_blank" rel="noopener">github</a>
		</div>
	</div>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: color-mix(in srgb, var(--paper) 82%, transparent);
		backdrop-filter: blur(10px) saturate(1.4);
		-webkit-backdrop-filter: blur(10px) saturate(1.4);
		border-bottom: 1px solid var(--rule);
	}
	.bar {
		width: var(--content-width);
		max-width: calc(100% - 2.4em);
		margin: 0 auto;
		padding: 0.85em 0;
		display: flex;
		align-items: baseline;
		gap: 1.6rem;
	}
	.logo {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 1.45rem;
		line-height: 1;
		letter-spacing: -0.01em;
		color: var(--ink);
		text-decoration: none;
		transition: color 0.18s ease;
	}
	.logo:hover {
		color: var(--accent);
	}
	.internal-links {
		display: flex;
		align-items: baseline;
		gap: 1.3rem;
		margin-left: auto;
	}
	.social-links {
		display: flex;
		align-items: baseline;
		gap: 1rem;
		padding-left: 1.3rem;
		border-left: 1px solid var(--rule);
	}
	.social-links a {
		font-family: var(--font-ui);
		font-size: 0.7rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--ink-faint);
		text-decoration: none;
		transition: color 0.18s ease;
	}
	.social-links a:hover {
		color: var(--accent);
	}

	@media (max-width: 720px) {
		.bar {
			gap: 1rem;
			flex-wrap: wrap;
		}
		.internal-links {
			gap: 1.1rem;
		}
		.social-links {
			gap: 0.85rem;
			padding-left: 1rem;
		}
	}
</style>
