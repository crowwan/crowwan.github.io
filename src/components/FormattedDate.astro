---
interface Props {
	date: Date;
}

const { date } = Astro.props;

// YYYY.MM.DD 형식(모노). ko-KR 점 구분.
const formatted = date
	.toLocaleDateString('ko-KR', {
		year: 'numeric',
		month: '2-digit',
		day: '2-digit',
	})
	.replace(/\.\s?/g, '.')
	.replace(/\.$/, '');
---

<time datetime={date.toISOString()}>{formatted}</time>

<style>
	time {
		font-family: var(--font-sans);
		letter-spacing: -0.01em;
	}
</style>
