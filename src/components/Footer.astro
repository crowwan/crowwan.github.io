---
const today = new Date();
---

<footer>
	<div class="colophon">
		<span class="copy">© {today.getFullYear()} CROWWAN</span>
		<span class="dot" aria-hidden="true">◆</span>
		<span class="note">DEV JOURNAL</span>
	</div>
	<div class="social-links">
		<a href="https://velog.io/@crowwan" target="_blank" rel="noopener">velog</a>
		<a href="https://github.com/crowwan" target="_blank" rel="noopener">github</a>
	</div>
</footer>
<style>
	footer {
		width: var(--content-width);
		max-width: calc(100% - 2.4em);
		margin: 0 auto;
		padding: 2.6em 1.2em 3.5em;
		border-top: 1px solid var(--border);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		font-family: var(--font-sans);
		font-size: 0.85rem;
		font-weight: 500;
		letter-spacing: -0.01em;
		color: var(--text-faint);
	}
	.colophon {
		display: flex;
		align-items: center;
		gap: 0.7rem;
	}
	.colophon .dot {
		font-size: 0.5rem;
		color: var(--accent);
	}
	.social-links {
		display: flex;
		gap: 1.1rem;
	}
	.social-links a {
		color: var(--text-meta);
		font-weight: 600;
		text-decoration: none;
		letter-spacing: -0.01em;
		transition: color 0.18s ease;
	}
	.social-links a:hover {
		color: var(--accent);
	}
	@media (max-width: 720px) {
		footer {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.9rem;
		}
	}
</style>
