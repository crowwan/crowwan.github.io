---
const today = new Date();
---

<footer>
	<span class="copy">© {today.getFullYear()} crowwan</span>
	<div class="social-links">
		<a href="https://velog.io/@crowwan" target="_blank" rel="noopener">velog</a>
		<a href="https://github.com/crowwan" target="_blank" rel="noopener">github</a>
	</div>
</footer>
<style>
	footer {
		width: var(--content-width);
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 2.5em 1em 3em;
		border-top: 1px solid var(--border);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--fg-muted);
	}
	.social-links {
		display: flex;
		gap: 1.2rem;
	}
	.social-links a {
		color: var(--fg-muted);
		text-decoration: none;
		transition: color 0.18s ease;
	}
	.social-links a:hover {
		color: var(--accent);
	}
	@media (max-width: 720px) {
		footer {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.8rem;
		}
	}
</style>
